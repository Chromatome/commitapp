# Copy this file to .env and fill in your values. .env is gitignored.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Showcase-only: "Get Started" on the landing page signs visitors straight
# into this account instead of sending them through signup. Create a
# dedicated demo user in Supabase Auth (with whatever sample profile/data
# you want visitors to see) and put its credentials here.
#
# Anyone who clicks "Get Started" gets full access to this account, so
# treat it like a public demo — don't reuse the password anywhere else,
# and don't put anything in this account you wouldn't want a stranger to
# see or change.
VITE_DEMO_USER_EMAIL=
VITE_DEMO_USER_PASSWORD=
